{
  "name": "@webeach-io/design",
  "version": "0.0.0",
  "description": "Design tokens for WebEach services",
  "license": "MIT",
  "author": {
    "name": "Ruslan Martynov",
    "email": "github@webea.ch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/webeach-io/webeach-design.git"
  },
  "files": [
    "assets",
    "dist",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js"
    },
    "./tokens.css": "./dist/tokens.css"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "generate:assets": "tsx ./scripts/generateAssets.ts",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:update": "vitest run -u",
    "test:watch": "vitest watch",
    "release": "semantic-release",
    "clean": "rm -rf dist",
    "prepare": "is-ci || husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/node": "^25.5.0",
    "husky": "^9.1.7",
    "is-ci": "^4.1.0",
    "lint-staged": "^16.3.3",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "semantic-release": "^25.0.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "zod": "^4.3.6"
  },
  "lint-staged": {
    "**/*.{cjs,cts,js,jsx,mjs,mts,ts,tsx,json}": [
      "oxlint --fix",
      "oxfmt"
    ]
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": "^10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
